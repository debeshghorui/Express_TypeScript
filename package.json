{
  "name": "todo-api",
  "version": "1.0.0",
  "description": "Todo API built with Express, TypeScript, drizzle-orm, and PostgreSQL",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc -p .",
    "dev": "tsc-watch --onSuccess \"node dist/server.js\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
